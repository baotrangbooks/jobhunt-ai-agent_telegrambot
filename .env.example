# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here_123456789:ABCDefGhIjKlMnoP

# Zalo OA Configuration (Optional)
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret

# Server Configuration (Optional)
HOST=0.0.0.0
PORT=8008
LOG_LEVEL=INFO

# AI Agent Configuration
# If omitted, the bot tries ../ai-agent-assistant.
AI_ASSISTANT_PATH=../ai-agent-assistant
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_ASSISTANT_TEMPERATURE=0
OPENAI_API_KEY=your_openai_api_key

# Job Search Catalog
# The bot also loads ../FastAPI-boilerplate/src/.env when present,
# so these can be omitted locally if the backend .env already has them.
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JOBS_TABLE=jobs
